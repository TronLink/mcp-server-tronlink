# ============================================
# mcp-server-tronlink 环境变量参考
# ============================================
# 本文件仅作为配置参考，不会被服务器读取。
# 所有变量必须通过 MCP JSON 配置的 env 字段注入：
#
#   .mcp.json（Claude Code 项目级）
#   claude_desktop_config.json（Claude Desktop）
#   settings.json（Claude Code 全局）
#
# 示例（.mcp.json）:
#   {
#     "mcpServers": {
#       "tronlink": {
#         "command": "node",
#         "args": ["dist/index.js"],
#         "env": {
#           "TL_TRONGRID_URL": "https://nile.trongrid.io",
#           "TL_CHAIN_PRIVATE_KEY": "your_64_hex_key"
#         }
#       }
#     }
#   }

# ── TronLink 扩展 ─────────────────────────────────
# TronLink 扩展 build 目录（含 manifest.json）
# 留空则自动检测: ./dist, ../tronlink-extension-pro/dist 等
TRONLINK_EXTENSION_PATH=

# TronLink 扩展源码目录（启用 tl_build 构建能力）
# 留空则不启用构建能力
TRONLINK_SOURCE_PATH=

# ── 运行模式 ──────────────────────────────────────
# 工作模式: e2e（本地测试链）或 prod（真实网络）
TL_MODE=prod

# 是否无头运行浏览器（true/false）
TL_HEADLESS=false

# Playwright 慢动作毫秒数（调试用，0=正常速度）
TL_SLOW_MO=0

# ── TronGrid API（链上操作） ─────────────────────
# TronGrid 全节点 API 地址
# 测试环境: https://nile.trongrid.io
# 生产环境: https://api.trongrid.io
TL_TRONGRID_URL=

# TronGrid API Key（Nile/Shasta 不需要，主网必填）
# 申请步骤:
#   1. 访问 https://www.trongrid.io/
#   2. 注册/登录 TronGrid 账号
#   3. 进入 Dashboard → Create API Key
#   4. 免费额度: 100,000 次/天（足够开发测试）
#   5. 将生成的 Key 填入下方
TL_TRONGRID_API_KEY=

# ── 多签服务（可选） ──────────────────────────────
# 配置以下 4 项后自动启用 tl_multisig_* 工具（5个工具）
# 测试环境: https://apinile.walletadapter.org
# 生产环境: https://api.walletadapter.org
TL_MULTISIG_BASE_URL=

# 多签服务凭证
# 申请步骤:
#   1. 联系 TronLink 团队申请多签服务接入凭证
#   2. 或使用 Nile 测试网默认凭证（仅供开发测试）:
#      SECRET_ID=TEST  SECRET_KEY=TESTTESTTEST  CHANNEL=test
#   3. 生产环境需正式申请（见 tron-multi-sig 项目 README）
TL_MULTISIG_SECRET_ID=
TL_MULTISIG_SECRET_KEY=
TL_MULTISIG_CHANNEL=

# ── 多签测试密钥（仅测试环境） ────────────────────
# ⚠️  仅用于 Nile/Shasta 测试网，切勿填入主网私钥！
# 多签 Owner 地址的私钥（64位十六进制）
# 用途: 设置多签权限（accountPermissionUpdate）、签署交易
TL_MULTISIG_OWNER_KEY=

# 多签联合签名者私钥（64位十六进制）
# 用途: 作为第二签名者测试多签交易
TL_MULTISIG_COSIGNER_KEY=

# ── 链上 API 模式（可选） ────────────────────────
# 配置私钥后启用 tl_chain_* 工具组（14个工具）
# 无需浏览器即可直接操作链上资产
# ⚠️  仅用于 Nile/Shasta 测试网，切勿填入主网私钥！
# 私钥（64位十六进制，无 0x 前缀）
TL_CHAIN_PRIVATE_KEY=

# SunSwap V2 Router 合约地址（用于 tl_chain_swap）
# 主网: TKzxdSv2FZKQrEqkKVgp5DcwEXBEKMg2Ax
# Nile 测试网可能未部署 SunSwap，留空则 swap 功能不可用
TL_SUNSWAP_ROUTER=

# SunSwap Smart Router 合约地址（用于 tl_chain_swap_v3，统一路由 V1/V2/V3）
# 来源: https://docs.sun.io/developers/swap/smart-router
# 主网: TCFNp179Lg46D16zKoumd4Poa2WFFdtqYj
# Nile: TB6xBCixqRPUSKiXb45ky1GhChFJ7qrfFj
# 注: 该合约是 SunSwap 统一路由入口，自动在 V1/V2/V3/PSM/SunCurve 池中选择最优路径
TL_SUNSWAP_V3_ROUTER=

# WTRX（Wrapped TRX）合约地址
# 主网: TNUC9Qb1rRpS5CbWLmNMxXBjyFoydXjWFR（默认值，无需手动设置）
# Nile: 需查询 SunSwap Router 的 WETH() 方法获取
# 查询方法: 调用 tl_chain_swap_v3 时若未设置，默认使用主网地址
TL_WTRX_ADDRESS=

# ── GasFree（免 Gas 转账，可选） ───────────────────
# 配置后启用 tl_gasfree_* 工具组（3个工具）
# GasFree 允许用户发送 TRC20 代币而无需支付 TRX Gas 费
#
# GasFree 服务地址
# 主网: https://open.gasfree.io/tron/
# Nile: https://open-test.gasfree.io/nile/
TL_GASFREE_BASE_URL=
#
# GasFree API Key + Secret 申请步骤:
#   1. 访问开发者中心: https://developer.gasfree.io/?lang=zh-CN
#   2. 注册开发者账号（需邮箱验证）
#   3. 创建应用 → 获取 API Key 和 API Secret
#   4. API 规范文档: https://gasfree.io/specification
#   5. SDK（可选参考）: npm install @gasfree/gasfree-sdk
#      GitHub: https://github.com/gasfreeio/gasfree-sdk-js
# 注: Nile 测试网也需要申请 Key，但审核较快
TL_GASFREE_API_KEY=
TL_GASFREE_API_SECRET=
